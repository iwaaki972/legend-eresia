// --- 1. FONCTIONS API (BACK-END) ---

// Charger les cosmétiques
async function chargerShowcase() {
    try {
        const response = await fetch(`${API_URL}/api/cosmetics`);
        if (!response.ok) throw new Error("Erreur serveur");
        const items = await response.json();
        
        const container = document.getElementById('showcase-container');
        container.innerHTML = ''; 

        items.forEach(item => {
            container.innerHTML += `
                <div class="feature-card" style="border-color: ${item.color || '#d4af37'}">
                    <img src="${item.img}" style="width:100%; height:150px; object-fit:cover; border-radius:8px; margin-bottom:10px;">
                    <h3 style="color:${item.color}">${item.category}</h3>
                    <p>${item.rarity}</p>
                </div>`;
        });
    } catch (e) { 
        document.getElementById('showcase-container').innerHTML = "<p>⚠️ Serveur non connecté. Les objets fictifs n'ont pas pu charger.</p>";
    }
}

// Charger les héros
async function chargerHeros() {
    try {
        const response = await fetch(`${API_URL}/api/heroes`);
        if (!response.ok) throw new Error("Erreur serveur");
        const heroes = await response.json();
        
        const listContainer = document.getElementById('heroes-container');
        listContainer.innerHTML = ''; 

        heroes.forEach(hero => {
            listContainer.innerHTML += `
                <li style="display:flex; align-items:center; gap:15px;">
                    <img src="${hero.img}" style="width:50px; height:50px; border-radius:50%; border: 2px solid #d4af37; object-fit:cover;">
                    <div>
                        <strong style="color: #d4af37; font-size: 1.2rem;">${hero.name}</strong> 
                        - <span style="font-style:italic;">${hero.title}</span>
                        <p style="font-size:0.9rem; color: #ccc;">${hero.desc}</p>
                    </div>
                </li>`;
        });
    } catch (e) {
        document.getElementById('heroes-container').innerHTML = "<li>⚠️ Impossible de charger la liste des héros depuis le serveur.</li>";
    }
}

// Ajouter un item (Bouton Admin)
async function ajouterItem() {
    const data = {
        category: document.getElementById('admin-name').value || "Nouvel Objet",
        rarity: document.getElementById('admin-rarity').value || "Commun",
        color: "#d4af37",
        img: document.getElementById('admin-img').value || "https://via.placeholder.com/150"
    };

    try {
        const response = await fetch(`${API_URL}/api/cosmetics`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
        });
        if (response.ok) {
            alert("Objet ajouté avec succès !");
            chargerShowcase(); 
        }
    } catch (error) {
        alert("Erreur lors de l'ajout (Le serveur est-il allumé ?)");
    }
}

// --- 2. FONCTIONS FRONT-END (BOUTONS & ANIMATIONS) ---

function setupButtons() {
    // Bouton COMING SOON -> Inscription
    const btnComingSoon = document.getElementById('btn-coming-soon');
    if (btnComingSoon) {
        btnComingSoon.addEventListener('click', async () => {
            const email = prompt("Entrez votre email pour être notifié du lancement :");
            if (email) {
                try {
                    const resp = await fetch(`${API_URL}/api/subscribe`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ email })
                    });
                    if (resp.ok) alert("Merci ! Vous êtes inscrit à la liste d'attente.");
                } catch (e) { 
                    alert("Erreur de connexion au serveur pour l'inscription."); 
                }
            }
        });
    }

    // Bouton PC -> Message
    const btnPc = document.getElementById('btn-pc');
    if (btnPc) {
        btnPc.addEventListener('click', () => {
            alert("Le launcher n'est pas encore disponible publiquement. Rejoignez le Discord !");
        });
    }
}

function setupAnimations() {
  const observer = new IntersectionObserver(entries => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.style.animationPlayState = 'running';
      }
    });
  }, { threshold: 0.1 });

  document.querySelectorAll('.fade-in, .fade-in-up, .fade-in-left, .fade-in-right').forEach(el => {
    el.style.animationPlayState = 'paused';
    observer.observe(el);
  });

  // Smooth scroll
  document.querySelectorAll('a[href^="#"]').forEach(anchor => {
    anchor.addEventListener('click', e => {
      e.preventDefault();
      const target = document.querySelector(anchor.getAttribute('href'));
      if (target) {
        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  });

  // Particules
  const hero = document.querySelector('.hero');
  for (let i = 0; i < 20; i++) {
    const particle = document.createElement('div');
    particle.className = 'particle';
    particle.style.left = Math.random() * 100 + '%';
    particle.style.top = Math.random() * 100 + '%';
    particle.style.animationDelay = Math.random() * 5 + 's';
    particle.style.animation = `float ${5 + Math.random() * 5}s ease-in-out infinite`;
    hero.appendChild(particle);
  }

  // Retour en haut
  const backToTopBtn = document.getElementById('backToTop');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 300) {
      backToTopBtn.classList.add('show');
    } else {
      backToTopBtn.classList.remove('show');
    }
  });
  
  backToTopBtn.addEventListener('click', () => {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });
}
</script>

